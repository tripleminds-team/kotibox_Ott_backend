            "variable": [{ "key": "genreId", "value": "<genre_id>" }]
          }
        }
      ]
    },
    {
      "name": "📄 Pages (Static Content)",
      "description": "Public static pages — Privacy Policy, Terms of Service, About Us, etc.",
      "item": [
        {
          "name": "List All Pages",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/pages",
            "description": "Get a list of all published static pages."
          }
        },
        {
          "name": "Get Page by Slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/pages/:slug",
