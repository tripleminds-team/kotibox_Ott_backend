            "variable": [{ "key": "slug", "value": "privacy-policy" }]
          }
        }
      ]
    },
    {
      "name": "❓ FAQs",
      "description": "Frequently Asked Questions — public endpoint for the app.",
      "item": [
        {
          "name": "List All FAQs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/faqs?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "faqs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Fetch all FAQs for the Help/Support section."
          }
        }
      ]
