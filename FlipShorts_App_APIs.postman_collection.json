{
  "info": {
    "_postman_id": "flipshorts-app-api-collection",
    "name": "FlipShorts App APIs",
    "description": "Complete API collection for the FlipShorts mobile app — includes authentication, subscription plans, content, movies, watch progress, downloads, wishlists, reviews, ads, and more. Base URL: https://flipshorts.app",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://flipshorts.app",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "JWT token received from login/verify-otp. Set this after authenticating."
    },
    {
      "key": "userId",
      "value": "",
      "type": "string",
      "description": "User ID returned after registration or login."
    },
    {
      "key": "contentId",
      "value": "",
      "type": "string",
      "description": "A content/show/movie ID."
    },
    {
      "key": "planId",
      "value": "",
      "type": "string",
      "description": "A subscription plan ID."
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 Authentication",
      "description": "App user authentication — OTP flow, email/password, Google, Apple Sign-In.",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/app/auth/send-otp",
            "description": "Send a one-time password to the user's phone or email for verification.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+919876543210\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/app/auth/verify-otp",
            "description": "Verify the OTP sent to the user. Returns a JWT token if successful.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+919876543210\",\n  \"otp\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/app/auth/register",
            "description": "Register a new app user with name, email, and password.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123\",\n  \"phone\": \"+919876543210\"\n}"
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/app/auth/login",
            "description": "Login with email and password. Returns accessToken.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            }
          }
        },
        {
          "name": "Google Auth",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/app/auth/google",
            "description": "Sign in / sign up using Google OAuth token.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"google_id_token_here\"\n}"
            }
          }
        },
        {
          "name": "Apple Auth",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/app/auth/apple",
            "description": "Sign in / sign up using Apple Sign-In token.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identityToken\": \"apple_identity_token_here\",\n  \"fullName\": {\n    \"givenName\": \"John\",\n    \"familyName\": \"Doe\"\n  }\n}"
            }
          }
        },
        {
          "name": "Set Preferred Language",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/app/auth/language/{{userId}}",
            "description": "Set the user's preferred content language after registration.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"languageId\": \"<language_id_here>\"\n}"
            }
          }
        },
        {
          "name": "Skip Language Selection",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/app/auth/language/{{userId}}/skip",
            "description": "Skip the preferred language selection step.",
            "header": []
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/app/auth/logout",
            "description": "Logout the user. Optionally provide deviceId to remove the device from push notification targets. The client must discard the JWT accessToken after calling this endpoint.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"optional-device-id-to-remove-push-token\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "👤 Profile",
      "description": "App user profile management — get, update, avatar upload, video quality, delete account.",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/app/profile",
            "description": "Get the authenticated user's profile details including subscription status."
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "PATCH",
            "url": "{{baseUrl}}/api/app/profile",
            "description": "Update name, email, or avatar URL.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\",\n  \"email\": \"john.updated@example.com\"\n}"
            }
          }
        },
        {
          "name": "Upload Avatar",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/app/profile/avatar",
            "description": "Upload a profile avatar image (multipart/form-data).",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "avatar", "type": "file", "src": "" }]
            }
          }
        },
        {
          "name": "Update Video Quality",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "PUT",
            "url": "{{baseUrl}}/api/app/profile/video-quality",
            "description": "Update the user's preferred video streaming quality.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quality\": \"1080p\"\n}"
            }
          }
        },
        {
          "name": "Update Language Preference",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "PUT",
            "url": "{{baseUrl}}/api/app/profile/language",
            "description": "Update the user's preferred content language.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"languageId\": \"<language_id_here>\"\n}"
            }
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/app/profile",
            "description": "Permanently delete the authenticated user's account."
          }
        }
      ]
    },
    {
      "name": "💳 Subscription Plans",
      "description": "Public and app-facing subscription plan listing. Used to display available plans in the app.",
      "item": [
        {
          "name": "List All Subscription Plans",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/subscription-plans?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "subscription-plans"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Fetch all subscription plans (Free, Basic, Premium, etc.)."
          }
        },
        {
          "name": "Get Subscription Plan by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/subscription-plans/{{planId}}",
            "description": "Get details of a single subscription plan including features and pricing."
          }
        }
      ]
    },
    {
      "name": "💰 Subscriptions (User)",
      "description": "Create, manage, and verify user subscriptions. Includes Razorpay payment integration.",
      "item": [
        {
          "name": "Create Razorpay Order",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/subscriptions/razorpay/order",
            "description": "Create a Razorpay payment order for a subscription plan. Returns order_id for the Razorpay SDK.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": \"{{planId}}\"\n}"
            }
          }
        },
        {
          "name": "Verify Razorpay Payment",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/subscriptions/razorpay/verify",
            "description": "Verify and activate the subscription after Razorpay payment is completed by the user.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"razorpay_order_id\": \"order_ABC123\",\n  \"razorpay_payment_id\": \"pay_XYZ456\",\n  \"razorpay_signature\": \"signature_hash_here\",\n  \"planId\": \"{{planId}}\"\n}"
            }
          }
        },
        {
          "name": "Get My Subscriptions",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/subscriptions",
            "description": "List the current user's subscription history."
          }
        }
      ]
    },
    {
      "name": "🏠 Home & Explore",
      "description": "App home page (banners, sections, featured content), explore page, and search.",
      "item": [
        {
          "name": "Get Home Page",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/home?platform=android",
              "host": ["{{baseUrl}}"],
              "path": ["api", "home"],
              "query": [
                { "key": "platform", "value": "android", "description": "android | ios" }
              ]
            },
            "description": "Fetch aggregated home page data — banners, trending, latest, continue watching, sections."
          }
        },
        {
          "name": "Explore Page (Infinite Scroll)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/explore?page=1&limit=20&genre=Action&type=movie",
              "host": ["{{baseUrl}}"],
              "path": ["api", "explore"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "genre", "value": "Action", "description": "Filter by genre name" },
                { "key": "type", "value": "movie", "description": "movie | show" }
              ]
            },
            "description": "Browse all content with pagination and filters for infinite scroll."
          }
        },
        {
          "name": "Search",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/search?q=action",
              "host": ["{{baseUrl}}"],
              "path": ["api", "search"],
              "query": [
                { "key": "q", "value": "action", "description": "Search query string" }
              ]
            },
            "description": "Search for movies, shows, or actors. Also returns trending keywords when query is empty."
          }
        }
      ]
    },
    {
      "name": "🎬 Movies (App)",
      "description": "App-facing movie detail page.",
      "item": [
        {
          "name": "Get Movie Detail (App)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/app/movies/{{contentId}}",
            "description": "Get full movie detail for the app — info, cast, related content, user like/wishlist status."
          }
        }
      ]
    },
    {
      "name": "▶️ Watch",
      "description": "Get video streaming data for a show/movie including episode list and video URLs.",
      "item": [
        {
          "name": "Get Watch Data",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/watch/{{contentId}}?season=1&episode=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "watch", "{{contentId}}"],
              "query": [
                { "key": "season", "value": "1", "description": "Season number (for shows)" },
                { "key": "episode", "value": "1", "description": "Episode number (for shows)" }
              ]
            },
            "description": "Fetch video player data — video URL, episode list, lock/unlock status based on subscription."
          }
        }
      ]
    },
    {
      "name": "📊 Watch Progress & History",
      "description": "Save and retrieve where the user left off watching. Full watch history management.",
      "item": [
        {
          "name": "Save Watch Progress",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/app/watch/progress",
            "description": "Save or update the user's watch progress for a specific content item.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contentId\": \"{{contentId}}\",\n  \"contentType\": \"movie\",\n  \"progressSeconds\": 1245,\n  \"totalSeconds\": 7200,\n  \"episodeId\": null,\n  \"seasonNumber\": null,\n  \"episodeNumber\": null\n}"
            }
          }
        },
        {
          "name": "Get Watch Progress (Single Item)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/app/watch/progress?contentId={{contentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "app", "watch", "progress"],
              "query": [{ "key": "contentId", "value": "{{contentId}}" }]
            },
            "description": "Get the saved watch progress for a specific content item."
          }
        },
        {
          "name": "Clear Watch Progress",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/app/watch/progress/{{contentId}}",
            "description": "Remove saved watch progress for a specific content item."
          }
        },
        {
          "name": "Get Watch History",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/app/watch/history",
            "description": "Get the full watch history for the authenticated user (sorted by last watched)."
          }
        },
        {
          "name": "Delete Watch History Item",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/app/watch/history/:id",
            "description": "Delete a specific item from the user's watch history.",
            "variable": [{ "key": "id", "value": "<history_item_id>" }]
          }
        },
        {
          "name": "Clear All Watch History",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/app/watch/history/all",
            "description": "Delete the entire watch history for the authenticated user."
          }
        }
      ]
    },
    {
      "name": "❤️ Wishlist (My List)",
      "description": "Toggle add/remove from wishlist and fetch the user's saved list.",
      "item": [
        {
          "name": "Toggle Wishlist",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/app/wishlist/{{contentId}}",
            "description": "Add or remove a content item from the user's wishlist (toggle).",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contentType\": \"movie\"\n}"
            }
          }
        },
        {
          "name": "Get My Wishlist",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/app/wishlist?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "app", "wishlist"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Fetch all content items in the user's wishlist with pagination."
          }
        }
      ]
    },
    {
      "name": "👍 Likes",
      "description": "Like or unlike a content item.",
      "item": [
        {
          "name": "Toggle Like",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/like/{{contentId}}",
            "description": "Toggle like/unlike on a movie or show.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contentType\": \"movie\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "⬇️ Downloads",
      "description": "Request, list, and manage offline downloads for the user.",
      "item": [
        {
          "name": "Request Download",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/app/download",
            "description": "Request authorization to download a content item (subscription required for premium content).",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contentId\": \"{{contentId}}\",\n  \"contentType\": \"movie\",\n  \"quality\": \"720p\"\n}"
            }
          }
        },
        {
          "name": "Get Downloads List",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/app/downloads",
            "description": "Get the list of all authorized downloads for the authenticated user."
          }
        },
        {
          "name": "Remove a Download",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/app/downloads/:id",
            "description": "Remove a specific download record.",
            "variable": [{ "key": "id", "value": "<download_id>" }]
          }
        },
        {
          "name": "Remove All Downloads",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/app/downloads",
            "description": "Remove all download records for the authenticated user."
          }
        }
      ]
    },
    {
      "name": "⭐ Reviews",
      "description": "App user reviews for content — post, fetch, and delete.",
      "item": [
        {
          "name": "Get Reviews for Content",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/app/reviews?contentId={{contentId}}&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "app", "reviews"],
              "query": [
                { "key": "contentId", "value": "{{contentId}}" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Get approved reviews for a specific content item."
          }
        },
        {
          "name": "Create Review",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/app/reviews",
            "description": "Submit a rating and review for a content item.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contentId\": \"{{contentId}}\",\n  \"contentType\": \"movie\",\n  \"rating\": 4,\n  \"review\": \"Amazing movie, highly recommended!\"\n}"
            }
          }
        },
        {
          "name": "Delete My Review",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/app/reviews/:id",
            "description": "Delete a review posted by the authenticated user.",
            "variable": [{ "key": "id", "value": "<review_id>" }]
          }
        }
      ]
    },
    {
      "name": "📢 Ads",
      "description": "Fetch active ads and record user interaction with them.",
      "item": [
        {
          "name": "Get Active Ads",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/app/ads",
            "description": "Fetch all currently active ads to display in the app."
          }
        },
        {
          "name": "Record Ad Interaction",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/app/ads/:id/interaction",
            "description": "Record a user interaction (click, view, skip) with an ad.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"click\"\n}"
            },
            "variable": [{ "key": "id", "value": "<ad_id>" }]
          }
        }
      ]
    },
    {
      "name": "🔔 Notifications",
      "description": "Public broadcast notifications (announcements, promos).",
      "item": [
        {
          "name": "Get Public Notifications",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/public/notifications",
            "description": "Fetch latest broadcast/announcement/promo notifications for the app."
          }
        }
      ]
    },
    {
      "name": "🌍 Genres",
      "description": "Public list of genres for content browsing and filtering.",
