PORT=3000
FRONTEND_URL=https://flipshorts.app
API_URL=https://flipshorts.app/api

# Deep Linking / Share settings
APP_PACKAGE_NAME=com.xoto.app
APP_SCHEME=xoto
APP_STORE_ID=123456789

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/triple-mindes

# Redis Connection
REDIS_URI=redis://localhost:6379

# AWS S3 Configuration
AWS_S3_ACCESS_KEY_ID=your-access-key-id
AWS_S3_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET_NAME=tripleminds-ott-admin
AWS_S3_REGION=us-east-1
